<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Employee Management Automation Suite">
    
    <!-- Wire our custom listener for Extent Reports and failure screenshots -->
    <listeners>
        <listener class-name="com.employee.automation.listeners.TestNGListener" />
    </listeners>

    <test name="Cucumber BDD Tests" preserve-order="true">
        <classes>
            <class name="runners.TestRunner" />
        </classes>
    </test>
</suite>
